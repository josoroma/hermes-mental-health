  "scoringRule": {
    "calculation": "average",
    "maxScale": 4,
    "severityThresholds": {
      "none": [
        0,
        1.49
      ],
      "mild": [
        1.5,
        2.49
      ],
      "moderate": [
        2.5,
        3.24
      ],
      "moderately_severe": [
        3.25,
        4
      ]
